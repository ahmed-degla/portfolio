<!-- Achievements -->
<section id="achievements" class="section section-alt">
    <div class="section-header reveal">
        <span class="section-tag">Achievements</span>
        <h2>Milestones & <span class="gradient-text">Highlights</span></h2>
    </div>
    <div class="achievements-grid reveal">
