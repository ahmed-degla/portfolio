<!-- Experience -->
<section id="experience" class="section section-alt">
    <div class="section-header reveal">
        <span class="section-tag">Experience</span>
        <h2>My <span class="gradient-text">Journey</span></h2>
        <p class="section-sub">Professional milestones and career highlights.</p>
    </div>
    <div class="timeline reveal">
        <div class="timeline-item">
            <div class="timeline-date">2024 — Present</div>
            <div class="timeline-content">
                <span class="timeline-company"><i class="fas fa-tools"></i> Active Development</span>
                <h3>Flutter Developer — SMSAR & Click FLEX</h3>
                <p>Currently building SMSAR, a classified ads marketplace for KSA (real estate, cars, electronics, license plates), and Click FLEX, a social platform connecting models with agents in the UAE.</p>
                <ul class="timeline-tags">
                    <li>Marketplace</li><li>Social Platform</li><li>Firebase</li><li>REST APIs</li>
                </ul>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-date">2023 — 2024</div>
            <div class="timeline-content">
                <span class="timeline-company"><i class="fas fa-rocket"></i> Published Apps</span>
                <h3>Flutter Developer — AMACADEMY & Otaibi Live</h3>
                <p>Developed and launched AMACADEMY (e-learning with videos, files, and electronic exams) and Otaibi Live — a social platform for the Otaibi tribe in Kuwait. Both published on App Store and Play Store.</p>
                <ul class="timeline-tags">
                    <li>E-Learning</li><li>Social</li><li>App Store</li><li>Play Store</li>
                </ul>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-date">2023 — Present</div>
            <div class="timeline-content">
                <span class="timeline-company"><i class="devicon-flutter-plain colored"></i> Professional Growth</span>
                <h3>Jr. Flutter Developer</h3>
                <p>Two years of dedicated Dart & Flutter experience building hybrid mobile apps across e-learning, social, and marketplace domains — from utility apps to complex platforms with robust functionalities.</p>
                <ul class="timeline-tags">
                    <li>Dart</li><li>Flutter</li><li>Clean Architecture</li><li>OOP</li>
                </ul>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-date">Ongoing</div>
            <div class="timeline-content">
                <span class="timeline-company"><i class="fab fa-github"></i> Open Source</span>
                <h3>Flutter Package Developer</h3>
        <article class="project-card" data-category="social">
            <div class="project-img" style="--accent:#FF6B9D">
                <div class="project-overlay"><span class="project-status live"><i class="fas fa-check-circle"></i> Live</span></div>
                <i class="fas fa-users project-icon"></i>
            </div>
            <div class="project-body">
                <span class="project-cat">Social Platform</span>
                <h3>Otaibi Live — لايف عتيبي</h3>
                <p>A social platform for the Otaibi tribe in Kuwait. Strengthens social bonds, shares news, participates in events, and provides a safe space to connect and capture special moments.</p>
                <div class="project-store-links">
                    <a href="#" class="store-link"><i class="fab fa-apple"></i> App Store</a>
                    <a href="#" class="store-link"><i class="fab fa-google-play"></i> Play Store</a>
                </div>
                <div class="project-tags"><span>Social</span><span>Events</span><span>Firebase</span><span>Kuwait</span></div>
            </div>
        </article>
        <article class="project-card" data-category="marketplace">
            <div class="project-img" style="--accent:#00D4FF">
                <div class="project-overlay"><span class="project-status dev"><i class="fas fa-code"></i> In Development</span></div>
                <i class="fas fa-store project-icon"></i>
            </div>
            <div class="project-body">
                <span class="project-cat">Classified Ads — KSA</span>
                <h3>SMSAR</h3>
                <p>A classified ads marketplace app in Saudi Arabia enabling users to buy, sell, and rent real estate, cars, electronics, phone numbers, license plates, and more.</p>
                <div class="project-tags"><span>Marketplace</span><span>Real Estate</span><span>Google Maps</span><span>KSA</span></div>
            </div>
        </article>
        <article class="project-card" data-category="social">
            <div class="project-img" style="--accent:#7E5CFF">
                <div class="project-overlay"><span class="project-status dev"><i class="fas fa-code"></i> In Development</span></div>
                <i class="fas fa-star project-icon"></i>
            </div>
            <div class="project-body">
                <span class="project-cat">Social Platform — UAE</span>
                <h3>Click FLEX</h3>
                <p>A social platform connecting models with agents in the UAE — built to streamline professional networking and collaboration in the modeling industry.</p>
                <div class="project-tags"><span>Social</span><span>Networking</span><span>UAE</span><span>Flutter</span></div>
            </div>
        </article>
        <article class="project-card" data-category="education">
            <div class="project-img" style="--accent:#6BCB77">
        <article class="project-card" data-category="education">
            <div class="project-img" style="--accent:#FFD93D">
    </div>
</section>

<!-- Process -->
<section id="process" class="section section-alt">
    <div class="section-header reveal">
        <span class="section-tag">Process</span>
        <h2>How I <span class="gradient-text">Work</span></h2>
        <p class="section-sub">A proven workflow that delivers results on time, every time.</p>
    </div>
    <div class="process-grid reveal">
        <div class="process-step"><div class="step-num">01</div><i class="fas fa-comments"></i><h3>Discovery</h3><p>Understanding your vision, goals, target users, and technical requirements through detailed consultation.</p></div>
        <div class="process-step"><div class="step-num">02</div><i class="fas fa-drafting-compass"></i><h3>Design & Plan</h3><p>Wireframes, architecture design, tech stack selection, and milestone planning with clear timelines.</p></div>
        <div class="process-step"><div class="step-num">03</div><i class="fas fa-code"></i><h3>Development</h3><p>Agile sprints with regular demos, clean code, comprehensive testing, and transparent progress updates.</p></div>
        <div class="process-step"><div class="step-num">04</div><i class="fas fa-vial"></i><h3>Testing & QA</h3><p>Rigorous testing across devices, performance profiling, bug fixes, and user acceptance testing.</p></div>
        <div class="process-step"><div class="step-num">05</div><i class="fas fa-rocket"></i><h3>Launch</h3><p>App Store & Play Store submission, ASO optimization, analytics setup, and go-live support.</p></div>
        <div class="process-step"><div class="step-num">06</div><i class="fas fa-headset"></i><h3>Support</h3><p>Ongoing maintenance, feature updates, performance monitoring, and dedicated post-launch support.</p></div>
    </div>
</section>

