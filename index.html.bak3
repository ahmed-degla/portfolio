            <li><a href="#testimonials">Highlights</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
        <a href="#contact" class="nav-cta">Hire Me</a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>
    </nav>
</header>

<!-- Hero -->
<section class="hero" id="home">
    <div class="hero-content">
        <div class="hero-badge reveal">
            <span class="pulse"></span>
            <span id="heroBadge"></span>
        </div>
        <p class="hero-greeting reveal" id="heroGreeting"></p>
        <h1 class="hero-name reveal" id="heroName"></h1>
        <h2 class="hero-title reveal"><span id="typedText"></span><span class="typed-cursor">|</span></h2>
        <p class="hero-desc reveal" id="heroDescription"></p>
        <div class="hero-stats reveal">
            <div class="hero-stat"><strong data-count="2">0</strong><span>Years Experience</span></div>
            <div class="hero-stat"><strong data-count="4">0</strong><span>Major Projects</span></div>
            <div class="hero-stat"><strong data-count="2">0</strong><span>Live on App Stores</span></div>
        </div>
        <div class="buttons reveal">
            <a href="#projects" class="btn"><i class="fas fa-rocket"></i> View My Work</a>
            <a href="#contact" class="btn-outline"><i class="fas fa-paper-plane"></i> Let's Talk</a>
            <a href="" class="btn-ghost" target="_blank" rel="noopener" id="cvLink"><i class="fas fa-download"></i> Download CV</a>
        </div>
        <div class="hero-social reveal" id="heroSocial">
        </div>
    </div>
    <div class="hero-visual reveal">
        <div class="hero-orbit">
            <div class="orbit-item" style="--i:0"><i class="devicon-flutter-plain colored"></i></div>
            <div class="orbit-item" style="--i:1"><i class="fas fa-fire"></i></div>
            <div class="orbit-item" style="--i:2"><i class="fas fa-code"></i></div>
            <div class="orbit-item" style="--i:3"><i class="fas fa-mobile-alt"></i></div>
        </div>
        <div class="glass-card">
            <div class="card-glow"></div>
            <img src="" alt="" id="profileImage">
            <div class="floating-badge badge-1"><i class="devicon-flutter-plain colored"></i> Flutter</div>
            <div class="floating-badge badge-2"><i class="fas fa-bolt"></i> 60 FPS</div>
            <div class="floating-badge badge-3"><i class="fas fa-layer-group"></i> Clean Arch</div>
        </div>
        <div class="hero-code-window">
            <div class="code-header"><span></span><span></span><span></span></div>
            <pre><code><span class="kw">class</span> <span class="cls">AhmedMohamedElDegla</span> {
  <span class="kw">final</span> skills = [
    <span class="str">'Flutter'</span>, <span class="str">'Dart'</span>,
    <span class="str">'Firebase'</span>, <span class="str">'REST APIs'</span>
  ];
  <span class="kw">void</span> buildApp() => <span class="fn">ship</span>();
}</code></pre>
        </div>
    </div>
</section>

<!-- Tech Marquee -->
<div class="marquee-section">
    <div class="marquee">
        <div class="marquee-track">
            <span><i class="fas fa-cubes"></i> Clean Architecture</span>
            <span><i class="fas fa-sitemap"></i> OOP</span>
            <span><i class="fas fa-mobile-alt"></i> Native iOS & Android</span>
            <span><i class="fas fa-credit-card"></i> BillingClient SDK</span>
            <span><i class="fab fa-git-alt"></i> Git</span>
            <span><i class="devicon-flutter-plain colored"></i> Flutter</span>
            <span><i class="fas fa-code"></i> Dart</span>
            <span><i class="fas fa-fire"></i> Firebase</span>
            <span><i class="fas fa-plug"></i> REST APIs</span>
            <span><i class="fas fa-map"></i> Google Maps</span>
            <span><i class="fas fa-globe"></i> Google APIs</span>
            <span><i class="fas fa-cubes"></i> Clean Architecture</span>
            <span><i class="fas fa-sitemap"></i> OOP</span>
            <span><i class="fas fa-mobile-alt"></i> Native iOS & Android</span>
            <span><i class="fas fa-credit-card"></i> BillingClient SDK</span>
            <span><i class="fab fa-git-alt"></i> Git</span>
        </div>
    </div>
</div>



<!-- About -->
<section id="about" class="section">
    <div class="section-header reveal">
        <span class="section-tag">About Me</span>
        <h2 id="aboutTitle"></h2>
        <p class="section-sub" id="aboutSubtitle"></p>
    </div>
    <div class="about-grid">
        <div class="about-image reveal">
            <div class="about-img-wrap">
                <img src="" alt="" id="aboutImage">
                <div class="about-exp-badge"><strong>2+</strong><span>Years Exp.</span></div>
            </div>
        </div>
        <div class="about-text reveal">
            <h3 id="aboutContent"></h3>
            <p id="aboutParagraph1"></p>
            <p id="aboutParagraph2"></p>
            <ul class="about-list" id="aboutList"></ul>
            <div class="about-info" id="aboutInfo"></div>
        </div>
    </div>
    <div class="stats reveal">
        <div class="stat"><h3 data-count="2">0</h3><p>Years Experience</p></div>
        <div class="stat"><h3 data-count="4">0</h3><p>Major Projects</p></div>
        <div class="stat"><h3 data-count="2">0</h3><p>Apps on Stores</p></div>
        <div class="stat"><h3 data-count="2">0</h3><p>In Development</p></div>
    </div>
</section>

<!-- Services -->
<section id="services" class="section section-alt">
    <div class="section-header reveal">
        <span class="section-tag">Services</span>
        <h2>What I <span class="gradient-text">Offer</span></h2>
        <p class="section-sub">End-to-end Flutter development services tailored to your needs.</p>
    </div>
    <div class="services-grid reveal">
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-mobile-alt"></i></div>
            <h3>Mobile App Development</h3>
            <p>Full-cycle Flutter apps for Android & iOS — from concept and wireframes to App Store launch.</p>
            <ul><li>Custom UI/UX</li><li>Native performance</li><li>Offline support</li></ul>
        </div>
        <div class="service-card featured">
            <div class="service-badge">Most Popular</div>
            <div class="service-icon"><i class="fas fa-fire"></i></div>
            <h3>Firebase Integration</h3>
            <p>Complete backend setup with Auth, Firestore, Cloud Functions, FCM, Analytics, and Crashlytics.</p>
            <ul><li>Real-time sync</li><li>Secure rules</li><li>Scalable infra</li></ul>
        </div>
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-paint-brush"></i></div>
            <h3>UI/UX Implementation</h3>
            <p>Transform Figma designs into responsive, animated Flutter widgets with micro-interactions.</p>
            <ul><li>Custom animations</li><li>Dark/Light themes</li><li>Responsive layouts</li></ul>
        </div>
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-sitemap"></i></div>
            <h3>Architecture & Refactoring</h3>
            <p>Migrate legacy code to Clean Architecture with proper state management and test coverage.</p>
            <ul><li>Bloc / Riverpod</li><li>Unit & widget tests</li><li>Code reviews</li></ul>
        </div>
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-plug"></i></div>
            <h3>API Integration</h3>
            <p>Connect your app to REST, GraphQL, WebSocket, payment gateways, maps, and third-party SDKs.</p>
            <ul><li>Stripe / PayPal</li><li>Google Maps</li><li>Social login</li></ul>
        </div>
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-rocket"></i></div>
            <h3>App Publishing & Support</h3>
            <p>Play Store & App Store submission, ASO optimization, and ongoing maintenance & updates.</p>
            <ul><li>Store compliance</li><li>Bug fixes</li><li>Feature updates</li></ul>
        </div>
    </div>
</section>

